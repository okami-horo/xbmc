apply plugin: 'com.android.application'

def escapeForJavaString = { value ->
    (value ?: "").replace("\\", "\\\\").replace("\"", "\\\"")
}

def buglyAppId = System.getenv("KODI_ANDROID_BUGLY_APP_ID") ?: ""
def buglyAppChannel = System.getenv("KODI_ANDROID_BUGLY_CHANNEL") ?: "official"
def buglyUploadDebug = (System.getenv("KODI_ANDROID_BUGLY_UPLOAD_DEBUG") ?: "false").toBoolean()

android {
    namespace = '@APP_PACKAGE@'
    compileSdk = @TARGET_SDK@
    ndkPath = "@NDKROOT@"
    ndkVersion = "@NDKVERSION@"
    defaultConfig {
        applicationId = "@APP_PACKAGE@"
        minSdk = @TARGET_MINSDK@
        targetSdk = @TARGET_SDK@
        versionCode = @APP_VERSION_CODE_ANDROID@
        versionName = "@APP_VERSION@"
        buildConfigField "String", "BUGLY_APP_ID", "\"${escapeForJavaString(buglyAppId)}\""
        buildConfigField "String", "BUGLY_APP_CHANNEL", "\"${escapeForJavaString(buglyAppChannel)}\""
        buildConfigField "boolean", "BUGLY_UPLOAD_IN_DEBUG", "${buglyUploadDebug}"
    }
    signingConfigs {
        release {
            keyAlias = System.getenv("KODI_ANDROID_KEY_ALIAS")
            keyPassword = System.getenv("KODI_ANDROID_KEY_PASSWORD")
            storeFile = file(System.getenv("KODI_ANDROID_STORE_FILE"))
            storePassword = System.getenv("KODI_ANDROID_STORE_PASSWORD")
            enableV1Signing = true
            enableV2Signing = true
            enableV3Signing = true
        }
    }
    buildTypes {
        debug {
            signingConfig = signingConfigs.release
            minifyEnabled false
            proguardFiles getDefaultProguardFile('proguard-android-optimize.txt'), 'proguard-rules.pro'
        }
        relwithdebinfo {
            signingConfig = signingConfigs.release
            minifyEnabled false
            proguardFiles getDefaultProguardFile('proguard-android-optimize.txt'), 'proguard-rules.pro'
        }
        release {
            signingConfig = signingConfigs.release
            minifyEnabled true
            proguardFiles getDefaultProguardFile('proguard-android-optimize.txt'), 'proguard-rules.pro'
        }
    }
    aaptOptions {
        ignoreAssetsPattern = '!.svn:!.git:!.ds_store:!*.scc:.*:!CVS:!thumbs.db:!picasa.ini:!*~'
    }
    sourceSets {
        main {
            manifest.srcFile 'AndroidManifest.xml'
            java.srcDirs = ['java']
            res.srcDirs = ['res']
            assets.srcDirs = ['assets']
            jniLibs.srcDirs = ['lib']
        }
    }
    packagingOptions{
      doNotStrip '**.setup'
      jniLibs {
          useLegacyPackaging = true
      }
    }
}

project.afterEvaluate {
    preBuild.dependsOn
}

dependencies {
    implementation 'androidx.core:core:1.16.0'
    implementation 'androidx.tvprovider:tvprovider:1.1.0'
    implementation 'com.google.code.gson:gson:2.13.1'
    implementation 'com.github.bilibili:DanmakuFlameMaster:0.9.25'
    implementation 'com.tencent.bugly:crashreport:4.1.9.3'
    implementation 'com.tencent.bugly:nativecrashreport:3.9.2'
}

java {
    toolchain {
        languageVersion = JavaLanguageVersion.of(17)
    }
}
